# -- Camera Config --------------------------------------
# Fallback camera list. MetroNet now syncs active cameras from the Laravel app first.
# Keep this only as a local backup if the app is temporarily unreachable.
# Single USB webcam (laptop):
CAMERAS=[{"id":1,"name":"Gate A","location":"Main Entrance","type":"usb","source":"0"}]

# Multiple cameras example:
# CAMERAS=[
#   {"id":1,"name":"Gate A","location":"Main Entrance","type":"usb","source":"0"},
#   {"id":2,"name":"Gate B","location":"Side Door","type":"rtsp","source":"rtsp://admin:admin@192.168.1.100:554/stream"},
#   {"id":3,"name":"Corridor","location":"Block 1","type":"rtsp","source":"rtsp://admin:admin@192.168.1.101:554/stream"}
# ]

# -- Laravel Connection ---------------------------------
LARAVEL_URL=http://127.0.0.1:8000
LARAVEL_INTERNAL_TOKEN=metronet-change-this-to-32char-secret
MODEL_PATH=./yolo26n.pt

# -- File Paths -----------------------------------------
FRAMES_DIR=../public/frames
SNAPSHOTS_DIR=../public/snapshots

# -- Detection Settings ---------------------------------
DETECTION_INTERVAL=3
MIN_CONFIDENCE=0.45
SNAPSHOT_ON_DETECTION=true
MAX_SNAPSHOTS=500
CAMERA_SYNC_INTERVAL=15

# -- Logging --------------------------------------------
LOG_LEVEL=INFO
